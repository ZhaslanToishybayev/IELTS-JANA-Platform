# Backend Environment Variables
# =============================

# Security (REQUIRED - change in production!)
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# Database
DATABASE_URL=sqlite:///./jana.db
# For production with PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/jana

# AI Configuration
# Default is local-first Ollama. Install Ollama and run:
#   ollama pull qwen2.5:7b
#   ollama serve
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_SEC=20

# Optional speech-to-text. If the Python whisper package is installed,
# Speaking can transcribe locally before Ollama scoring.
WHISPER_MODEL=base

# Optional cloud fallback. Use AI_PROVIDER=gemini or AI_PROVIDER=auto to enable it.
GEMINI_API_KEY=

# Email Configuration (SMTP)
# For Gmail: enable "Less secure apps" or use App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@ielts-jana.com
SMTP_FROM_NAME=IELTS JANA
SMTP_USE_TLS=true

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Email Token Expiry
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_HOURS=1
